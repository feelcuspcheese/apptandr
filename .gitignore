```
# Android build artifacts
*.apk
*.aar
*.dex

# Android cache and build directories
.build/
.externalNativeBuild/
.gradle/
local.properties

# Android Studio
.idea/
*.iml
*.iws
*.log

# Android specific
captures/
*.keystore
debug.keystore

# Kotlin
*.kotlin_metadata

# Gradle
.gradle/
!gradle/wrapper/

# Local configuration file (sdk path, etc)
local.properties

# Proguard folder generated by Eclipse when using ProGuard
proguard/

# Log Files
*.log

# Android Coverage
coverage/

# Exclude generated native build artifacts
**/.cxx/**
```